# OAuth credentials for the Import Data page's cloud connectors.
#
# Copy this file to `secrets.toml` (which is git-ignored) and fill in the
# values from each provider's app console. Without it, computer upload still
# works and the cloud sources simply show setup instructions.

[oauth]
# Must EXACTLY match a redirect URI registered in both provider consoles.
# Point it at the running Import page, e.g. http://localhost:8501/import_data
redirect_uri = "http://localhost:8501/import_data"

# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client
# (type: Web application). Enable the Google Drive API for the project.
[google_drive]
client_id = "your-client-id.apps.googleusercontent.com"
client_secret = "your-client-secret"

# Dropbox App Console -> your app (scoped access). Grant the
# files.metadata.read and files.content.read permissions.
[dropbox]
app_key = "your-app-key"
app_secret = "your-app-secret"
